<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <service id="Swag\McpAdminUsers\Mcp\AdminUsersTool">
            <argument type="service" id="user.repository"/>
            <argument type="service" id="Shopware\Core\Framework\Mcp\Context\McpContextProvider"/>
            <tag name="shopware.mcp.tool"/>
            <tag name="shopware.feature" flag="MCP_SERVER"/>
        </service>

        <service id="Swag\McpAdminUsers\Mcp\AdminRolesTool">
            <argument type="service" id="acl_role.repository"/>
            <argument type="service" id="Shopware\Core\Framework\Mcp\Context\McpContextProvider"/>
            <tag name="shopware.mcp.tool"/>
            <tag name="shopware.feature" flag="MCP_SERVER"/>
        </service>

        <service id="Swag\McpAdminUsers\Mcp\AdminContextPrompt">
            <tag name="shopware.mcp.prompt"/>
            <tag name="shopware.feature" flag="MCP_SERVER"/>
        </service>

        <service id="Swag\McpAdminUsers\Mcp\AdminUsagePrompt">
            <tag name="shopware.mcp.prompt"/>
            <tag name="shopware.feature" flag="MCP_SERVER"/>
        </service>

        <service id="Swag\McpAdminUsers\Mcp\AdminUsersResource">
            <argument type="service" id="user.repository"/>
            <tag name="shopware.mcp.resource"/>
            <tag name="shopware.feature" flag="MCP_SERVER"/>
        </service>

        <service id="Swag\McpAdminUsers\Mcp\AdminRolesResource">
            <argument type="service" id="acl_role.repository"/>
            <tag name="shopware.mcp.resource"/>
            <tag name="shopware.feature" flag="MCP_SERVER"/>
        </service>
    </services>
</container>
